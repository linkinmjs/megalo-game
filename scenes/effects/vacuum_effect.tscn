; ── Partículas de succión — dos emisores en cono desde las esquinas del viewport ─
; Emisores en coordenadas LOCALES (local_coords=true) para que sigan la aspiradora.
; Vacío activo en world x=-580. Local x=1280 → world x=700 (justo fuera del borde derecho).
; Local y=±380 cubre las esquinas del viewport (720/2=360 + margen).
; Direcciones calculadas hacia la boca (~local x=50, y=0):
;   Upper: normalize(50-1280, 0-(-380)) = normalize(-1230, 380) ≈ (-0.956, 0.295)
;   Lower: normalize(-1230, -380) ≈ (-0.956, -0.295)
; Lifetime 1.65s × avg 780px/s ≈ 1287 unidades = distancia exacta a la boca → fade justo al llegar.
[node name="SuctionParticles" type="Node2D" parent="."]

[node name="SuctionParticlesUpper" type="CPUParticles2D" parent="SuctionParticles"]
position = Vector2(1280, -380)
emitting = false
amount = 60
lifetime = 1.65
lifetime_randomness = 0.2
local_coords = true
direction = Vector2(-0.956, 0.295)
spread = 28.0
gravity = Vector2(0, 0)
initial_velocity_min = 680.0
initial_velocity_max = 880.0
scale_amount_min = 1.5
scale_amount_max = 3.5
color_ramp = SubResource("Gradient_suction")

